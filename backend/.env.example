# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seatmaster
DB_USER=postgres
DB_PASSWORD=your_password

# Server
PORT=3000

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
# Leave blank or set PAYMENT_PROVIDER=mock to use mock payments (no Razorpay UI)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Set to "mock" to bypass Razorpay entirely (default behavior when keys are missing)
# PAYMENT_PROVIDER=mock
